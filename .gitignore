# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# superpowers/SDD workflow scratch space (briefs, ledgers) — never commit
.superpowers/

/src/generated/prisma

# Claude Code harness state — machine-local (session GUIDs, absolute paths,
# local username), no secrets, but not meant to be shared via the repo
.claude/
.permlog/
.timelog/
